# ==========================================================================
# Porville — Environment Variables
# Copy this file to `.env.local` for local development and set real values.
# On Vercel, add each of these under Project Settings → Environment Variables.
# NEVER commit real secrets. Only NEXT_PUBLIC_* values are exposed to the browser.
# ==========================================================================

# --- Database (server only) ---
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/porville

# --- NextAuth (server only) ---
# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET=some-long-random-string-here
# Public URL of the deployment. Local: http://localhost:3000
# Production: https://your-domain.com  (must match the Google OAuth redirect URI host)
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth (server only) ---
# Authorized redirect URI in Google Cloud Console must be:
#   <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Razorpay (KEY_ID + SECRET are server only; NEXT_PUBLIC_* is the browser key) ---
RAZORPAY_KEY_ID=rzp_test_yourkeyid
RAZORPAY_KEY_SECRET=yourkeysecret
# Same value as RAZORPAY_KEY_ID; safe to expose to the frontend checkout widget.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_yourkeyid

# --- Demo Checkout Fallback ---
# Set to 'true' to allow demo checkouts. Also implicitly enabled in local dev if Razorpay keys are missing.
NEXT_PUBLIC_DEMO_CHECKOUT_ENABLED=true

# --- Delivery charge testing switch ---
# When 'true', the delivery fee is forced to 0 everywhere (cart, checkout, order
# creation and the Razorpay amount) and the free-delivery threshold behaves as 0.
# Admin delivery settings (deliveryCharge / freeDeliveryThreshold) are NOT removed
# — they are only bypassed at calculation time. Delivery is ENABLED by default;
# it is only disabled when these are explicitly 'true'. Set BOTH to 'true' to run
# another payment-testing round. NEXT_PUBLIC_* is the only value the browser cart
# can read; keep both in sync.
DISABLE_DELIVERY_CHARGE_FOR_TESTING=false
NEXT_PUBLIC_DISABLE_DELIVERY_CHARGE_FOR_TESTING=false

# --- Cloudinary (server only) ---
CLOUDINARY_CLOUD_NAME=yourcloudinarycloudname
CLOUDINARY_API_KEY=yourcloudinaryapikey
CLOUDINARY_API_SECRET=yourcloudinaryapisecret

# --- Initial admin user (used by /api/seed when creating the first admin) ---
# Choose your own strong values. Do NOT reuse any previously committed default.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=choose-a-strong-password

# --- Seed route protection (server only) ---
# Required to run /api/seed at all. Generate with: openssl rand -hex 24
SEED_SECRET=generate-a-strong-random-secret
